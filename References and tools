-- ... internal connections ...

inst_display: display_driver
    port map (
        -- ... other ports ...
        anode => s_an_4, -- Connect the driver's 4-bit output here
        -- ...
    );

-- THIS LINE TURNS OFF THE LEFT 4 DIGITS
